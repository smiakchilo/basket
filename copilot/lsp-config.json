{
  "lspServers": {
    "java": {
      "command": "jdtls",
      "args": [
        "--stdio"
      ],
      "fileExtensions": {
        ".java": "java"
      }
    },
    "typescript": {
      "command": "typescript-language-server",
      "args": [
        "--stdio"
      ],
      "fileExtensions": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact",
        ".mjs": "javascript",
        ".cjs": "javascript"
      }
    }
  }
}
